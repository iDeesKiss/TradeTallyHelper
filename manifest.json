{
    "manifest_version": 3,
    "name": "Trade Tally Helper",
    "version": "0.1",
    "icons":{
        "16":"tth_icon.png",
        "48":"tth_icon.png",
        "128":"tth_icon.png"
    },
    "content_scripts": [ 
        {
        "matches": ["*://buff.163.com/goods/*"
        ],
        "js": [
            "buff163/js/main.js",
            "buff163/js/update_goods.js",
            "buff163/js/utility.js",
            "buff163/js/set_color.js"
        ],
        "css": [
            "buff163/css/goods.css"
        ]
    }
    ],
    "permissions": []
}
